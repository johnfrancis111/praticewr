<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Calc + Conditionals</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=Fraunces:ital,wght@0,300;0,700;1,300&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --cream: #f5f0e8;
  --paper: #ede8dc;
  --tan:   #d4c9b0;
  --ink:   #1a1712;
  --rust:  #c0392b;
  --moss:  #2d6a4f;
  --gold:  #b8860b;
  --mono:  'DM Mono', monospace;
  --serif: 'Fraunces', Georgia, serif;
}

body {
  background: var(--cream);
  color: var(--ink);
  font-family: var(--mono);
  min-height: 100vh;
  padding: 32px 20px;
  background-image:
    repeating-linear-gradient(0deg, transparent, transparent 27px, rgba(0,0,0,0.04) 27px, rgba(0,0,0,0.04) 28px);
}

header {
  text-align: center;
  margin-bottom: 36px;
}

header h1 {
  font-family: var(--serif);
  font-weight: 700;
  font-size: clamp(2rem, 6vw, 3.2rem);
  letter-spacing: -0.02em;
  line-height: 1;
  color: var(--ink);
}

header h1 em {
  font-style: italic;
  font-weight: 300;
  color: var(--rust);
}

header p {
  margin-top: 8px;
  font-size: 0.7rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold);
}

.layout {
  max-width: 820px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  align-items: start;
}

@media (max-width: 580px) {
  .layout { grid-template-columns: 1fr; }
}

/* ── CARD ── */
.card {
  background: var(--paper);
  border: 2px solid var(--ink);
  box-shadow: 5px 5px 0 var(--ink);
  padding: 24px;
}

.card-label {
  font-size: 0.6rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--rust);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.card-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--tan);
}

/* ── CALCULATOR ── */
.display-wrap {
  background: var(--ink);
  padding: 16px;
  margin-bottom: 16px;
}

.display-sub {
  font-size: 0.65rem;
  color: var(--tan);
  min-height: 14px;
  text-align: right;
  letter-spacing: 0.05em;
  margin-bottom: 4px;
  font-style: italic;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.display-main {
  font-family: var(--serif);
  font-size: clamp(1.6rem, 5vw, 2.4rem);
  font-weight: 700;
  color: var(--cream);
  text-align: right;
  letter-spacing: -0.02em;
  line-height: 1;
  word-break: break-all;
  transition: color 0.15s;
}

.display-main.err { color: var(--rust); }

.btn-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6px;
}

.btn {
  font-family: var(--mono);
  font-size: 0.85rem;
  font-weight: 500;
  padding: 13px 4px;
  border: 1.5px solid var(--ink);
  background: var(--cream);
  color: var(--ink);
  cursor: pointer;
  transition: background 0.1s, transform 0.07s, box-shadow 0.07s;
  box-shadow: 2px 2px 0 var(--ink);
  user-select: none;
}

.btn:hover  { background: var(--tan); }
.btn:active { transform: translate(2px,2px); box-shadow: none; }

.btn.op   { color: var(--rust); font-weight: 700; }
.btn.fn   { color: var(--gold); font-size: 0.72rem; }
.btn.eq   { background: var(--ink); color: var(--cream); font-weight: 700; box-shadow: 2px 2px 0 var(--rust); }
.btn.eq:hover { background: #2d2922; }
.btn.clr  { color: var(--rust); font-weight: 700; }

/* ── CONDITIONALS ── */
.cond-item {
  margin-bottom: 18px;
}

.cond-item:last-child { margin-bottom: 0; }

.cond-name {
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 8px;
}

.input-row {
  display: flex;
  gap: 6px;
  align-items: center;
  flex-wrap: wrap;
}

.inp {
  background: var(--cream);
  border: 1.5px solid var(--ink);
  font-family: var(--mono);
  font-size: 0.85rem;
  padding: 8px 10px;
  color: var(--ink);
  width: 80px;
  outline: none;
  box-shadow: 2px 2px 0 var(--tan);
}

.inp:focus { border-color: var(--rust); }

.inp-sep {
  font-size: 0.7rem;
  color: var(--tan);
}

.run {
  font-family: var(--mono);
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 8px 12px;
  background: var(--ink);
  color: var(--cream);
  border: 1.5px solid var(--ink);
  cursor: pointer;
  box-shadow: 2px 2px 0 var(--rust);
  transition: transform 0.07s, box-shadow 0.07s;
}

.run:hover  { background: #2d2922; }
.run:active { transform: translate(2px,2px); box-shadow: none; }

.result {
  margin-top: 8px;
  font-size: 0.78rem;
  padding: 8px 10px;
  border-left: 3px solid var(--moss);
  background: rgba(45,106,79,0.07);
  color: var(--moss);
  min-height: 32px;
  font-style: italic;
  transition: border-color 0.2s, color 0.2s, background 0.2s;
  line-height: 1.4;
}

.result.neg  { border-color: var(--rust); color: var(--rust); background: rgba(192,57,43,0.06); }
.result.warn { border-color: var(--gold); color: var(--gold); background: rgba(184,134,11,0.07); }
.result.muted { color: var(--tan); border-color: var(--tan); background: transparent; }

hr.divider {
  border: none;
  border-top: 1px dashed var(--tan);
  margin: 14px 0;
}
</style>
</head>
<body>

<header>
  <h1>Calc<em> &amp; </em>Logic</h1>
  <p>Simple Calculator · Conditional Solver</p>
</header>

<div class="layout">

  <!-- ══ CALCULATOR ══ -->
  <div class="card">
    <div class="card-label">Simple Calculator</div>

    <div class="display-wrap">
      <div class="display-sub" id="expr"></div>
      <div class="display-main" id="display">0</div>
    </div>

    <div class="btn-grid">
      <button class="btn clr" onclick="clearAll()">AC</button>
      <button class="btn fn"  onclick="toggleSign()">±</button>
      <button class="btn fn"  onclick="percent()">%</button>
      <button class="btn op"  onclick="inputOp('/')">÷</button>

      <button class="btn" onclick="inputNum('7')">7</button>
      <button class="btn" onclick="inputNum('8')">8</button>
      <button class="btn" onclick="inputNum('9')">9</button>
      <button class="btn op"  onclick="inputOp('*')">×</button>

      <button class="btn" onclick="inputNum('4')">4</button>
      <button class="btn" onclick="inputNum('5')">5</button>
      <button class="btn" onclick="inputNum('6')">6</button>
      <button class="btn op"  onclick="inputOp('-')">−</button>

      <button class="btn" onclick="inputNum('1')">1</button>
      <button class="btn" onclick="inputNum('2')">2</button>
      <button class="btn" onclick="inputNum('3')">3</button>
      <button class="btn op"  onclick="inputOp('+')">+</button>

      <button class="btn" style="grid-column:span 2" onclick="inputNum('0')">0</button>
      <button class="btn" onclick="inputDot()">.</button>
      <button class="btn eq" onclick="calculate()">=</button>
    </div>
  </div>

  <!-- ══ CONDITIONALS ══ -->
  <div class="card">
    <div class="card-label">Conditional Solver</div>

    <!-- 1. Classify -->
    <div class="cond-item">
      <div class="cond-name">① classifyNumber(n)</div>
      <div class="input-row">
        <input class="inp" id="cn-in" type="number" placeholder="e.g. −7">
        <button class="run" onclick="runClassify()">Run →</button>
      </div>
      <div class="result muted" id="cn-out">awaiting input…</div>
    </div>

    <hr class="divider">

    <!-- 2. Compare -->
    <div class="cond-item">
      <div class="cond-name">② compareNumbers(a, b)</div>
      <div class="input-row">
        <input class="inp" id="cmp-a" type="number" placeholder="a">
        <span class="inp-sep">vs</span>
        <input class="inp" id="cmp-b" type="number" placeholder="b">
        <button class="run" onclick="runCompare()">Run →</button>
      </div>
      <div class="result muted" id="cmp-out">awaiting input…</div>
    </div>

    <hr class="divider">

    <!-- 3. Grade -->
    <div class="cond-item">
      <div class="cond-name">③ getGrade(score)</div>
      <div class="input-row">
        <input class="inp" id="gr-in" type="number" min="0" max="100" placeholder="0–100">
        <button class="run" onclick="runGrade()">Run →</button>
      </div>
      <div class="result muted" id="gr-out">awaiting input…</div>
    </div>

    <hr class="divider">

    <!-- 4. FizzBuzz -->
    <div class="cond-item">
      <div class="cond-name">④ fizzBuzz(n)</div>
      <div class="input-row">
        <input class="inp" id="fz-in" type="number" placeholder="e.g. 15">
        <button class="run" onclick="runFizzBuzz()">Run →</button>
      </div>
      <div class="result muted" id="fz-out">awaiting input…</div>
    </div>

  </div>
</div>

<script>
/* ═══════════════════════════════════════
   SIMPLE CALCULATOR
═══════════════════════════════════════ */
let current = '0', prev = '', op = null, fresh = false;

const SYMS = { '+': '+', '-': '−', '*': '×', '/': '÷' };

function setDisplay(val, expr = '') {
  const d = document.getElementById('display');
  const e = document.getElementById('expr');
  const s = String(val);
  const shown = s.length > 13 ? parseFloat(parseFloat(s).toPrecision(10)) : s;
  d.textContent = shown;
  d.className = 'display-main' + (s.startsWith('Err') ? ' err' : '');
  e.textContent = expr;
}

function inputNum(n) {
  if (fresh) { current = n; fresh = false; }
  else current = (current === '0') ? n : current + n;
  setDisplay(current);
}

function inputDot() {
  if (fresh) { current = '0.'; fresh = false; }
  else if (!current.includes('.')) current += '.';
  setDisplay(current);
}

function inputOp(o) {
  if (op && !fresh) calculate();
  prev = current; op = o; fresh = true;
  setDisplay(current, current + ' ' + SYMS[o]);
}

function calculate() {
  if (!op || !prev) return;
  const a = parseFloat(prev), b = parseFloat(current);
  let r;
  if      (op === '+') r = a + b;
  else if (op === '-') r = a - b;
  else if (op === '*') r = a * b;
  else if (op === '/') r = b === 0 ? 'Error: ÷ 0' : a / b;
  setDisplay(r, `${prev} ${SYMS[op]} ${current} =`);
  current = String(r); op = null; prev = ''; fresh = true;
}

function clearAll() {
  current = '0'; prev = ''; op = null; fresh = false;
  setDisplay('0', '');
}

function toggleSign() {
  current = String(parseFloat(current) * -1);
  setDisplay(current);
}

function percent() {
  current = String(parseFloat(current) / 100);
  setDisplay(current);
}

/* ═══════════════════════════════════════
   CONDITIONAL FUNCTIONS
═══════════════════════════════════════ */

/* ① Classify a number */
function classifyNumber(n) {
  if (isNaN(n)) return { text: 'Not a number', cls: 'warn' };
  if (n > 0)    return { text: `${n} is Positive`, cls: '' };
  if (n < 0)    return { text: `${n} is Negative`, cls: 'neg' };
  return              { text: `${n} is Zero`, cls: 'warn' };
}

function runClassify() {
  const v = parseFloat(document.getElementById('cn-in').value);
  const r = classifyNumber(v);
  const el = document.getElementById('cn-out');
  el.textContent = r.text;
  el.className = 'result ' + r.cls;
}

/* ② Compare two numbers */
function compareNumbers(a, b) {
  if (a > b) return { text: `${a} > ${b}  —  a is greater`, cls: '' };
  if (a < b) return { text: `${b} > ${a}  —  b is greater`, cls: 'neg' };
  return           { text: `${a} = ${b}  —  equal`, cls: 'warn' };
}

function runCompare() {
  const a = parseFloat(document.getElementById('cmp-a').value);
  const b = parseFloat(document.getElementById('cmp-b').value);
  if (isNaN(a) || isNaN(b)) {
    const el = document.getElementById('cmp-out');
    el.textContent = 'Enter two valid numbers'; el.className = 'result warn'; return;
  }
  const r = compareNumbers(a, b);
  const el = document.getElementById('cmp-out');
  el.textContent = r.text; el.className = 'result ' + r.cls;
}

/* ③ Grade classifier */
function getGrade(score) {
  if (isNaN(score) || score < 0 || score > 100)
    return { text: 'Score must be between 0 and 100', cls: 'warn' };
  if (score >= 90) return { text: `${score} → A  (Excellent)`, cls: '' };
  if (score >= 80) return { text: `${score} → B  (Good)`, cls: '' };
  if (score >= 70) return { text: `${score} → C  (Average)`, cls: 'warn' };
  if (score >= 60) return { text: `${score} → D  (Below average)`, cls: 'warn' };
  return                  { text: `${score} → F  (Failing)`, cls: 'neg' };
}

function runGrade() {
  const v = parseFloat(document.getElementById('gr-in').value);
  const r = getGrade(v);
  const el = document.getElementById('gr-out');
  el.textContent = r.text; el.className = 'result ' + r.cls;
}

/* ④ FizzBuzz */
function fizzBuzz(n) {
  if (isNaN(n) || !Number.isInteger(n))
    return { text: 'Enter a whole integer', cls: 'warn' };
  if (n % 15 === 0) return { text: `${n} → FizzBuzz  (÷3 and ÷5)`, cls: '' };
  if (n % 3  === 0) return { text: `${n} → Fizz  (divisible by 3)`, cls: '' };
  if (n % 5  === 0) return { text: `${n} → Buzz  (divisible by 5)`, cls: 'warn' };
  return                   { text: `${n} → ${n}  (no match)`, cls: 'neg' };
}

function runFizzBuzz() {
  const v = parseInt(document.getElementById('fz-in').value, 10);
  const r = fizzBuzz(v);
  const el = document.getElementById('fz-out');
  el.textContent = r.text; el.className = 'result ' + r.cls;
}
</script>
</body>
</html>
